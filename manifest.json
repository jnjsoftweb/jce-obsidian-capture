{
  "manifest_version": 3,
  "name": "Full Page Capture to Obsidian",
  "version": "1.0",
  "permissions": ["activeTab", "scripting", "downloads"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  }
}