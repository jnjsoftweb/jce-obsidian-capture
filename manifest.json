{
    "manifest_version": 3,
    "name": "Full Page Capture to Obsidian",
    "version": "1.0",
    "description": "Capture full page and save to Obsidian",
    "permissions": [
        "activeTab",
        "scripting",
        "downloads"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "dist/background.js",
        "type": "module"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "dist/contentScript.js"
            ]
        }
    ]
}